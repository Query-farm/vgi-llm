# name: test/sql/secrets.test
# description: llm — provider keys are configurable via a DuckDB CREATE SECRET (TYPE llm). DDL/bind only, no network, no real keys.
# group: [vgi_llm]

require-env VGI_TEST_WORKER

statement ok
LOAD vgi;

statement ok
ATTACH 'llm' AS ai (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# The `llm` secret type is registered by the worker, and all four provider
# fields (anthropic/openrouter/openai keys + ollama_host) are accepted.
statement ok
CREATE SECRET llm_keys (
    TYPE llm,
    anthropic_api_key 'sk-ant-test',
    openrouter_api_key 'sk-or-test',
    openai_api_key 'sk-test',
    ollama_host 'http://localhost:11434/v1'
);

# The secret exists and is typed `llm`.
query TT
SELECT name, type FROM duckdb_secrets() WHERE name = 'llm_keys';
----
llm_keys	llm

statement ok
DROP SECRET llm_keys;
